# Enforce LF line endings on all files when checked out on any OS
* text=auto eol=lf

# Explicitly LF for files that must not have CRLF (shell scripts, Python, configs)
*.sh text eol=lf
*.py text eol=lf
*.conf text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.env.template text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Treat binary files as binary (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
*.pem binary
