# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-generate-with-secrets-token-hex-32

# Main MySQL database (app data)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=trialguard
DB_USER=tg_app
DB_PASS=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# MongoDB (health telemetry)
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB_NAME=trialguard_telemetry
MONGO_USER=tg_mongo
MONGO_PASS=change-me-mongo-password

# Redis
REDIS_URL=redis://redis:6379

# PII Vault service
VAULT_URL=http://pii_vault:8888
VAULT_SHARED_SECRET=change-me-generate-with-secrets-token-hex-32

# Vault MySQL database (isolated — separate from app DB)
VAULT_DB_HOST=vault_db
VAULT_DB_PORT=3306
VAULT_DB_NAME=pii_vault
VAULT_DB_USER=vault_app
VAULT_DB_PASS=change-me-vault-db-password
VAULT_MYSQL_ROOT_PASSWORD=change-me-vault-root-password

# AES-256 encryption key for PII at rest in vault (32 bytes, hex-encoded)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
VAULT_ENCRYPTION_KEY=change-me-generate-32-byte-hex-key

# SMTP (email verification) — use Mailtrap sandbox for dev/testing
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=change-me-smtp-user
SMTP_PASS=change-me-smtp-pass
SMTP_FROM=noreply@trialguard.com
APP_URL=https://medi.trialguard.com
